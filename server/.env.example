# server/.env.example
# 実際の値を入れて `.env` という名前で保存する（.env はGit管理外）

# Webhookの x-line-signature 検証に使う。
# LINE Developersコンソール → ミニアプリチャネル基本情報 → チャネルシークレット
LINE_CHANNEL_SECRET=

# 購入予約APIを叩くときの認証用。
# LINE Developersコンソール → ミニアプリチャネル基本情報 → チャネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=

# 購入予約APIのエンドポイント。空のままだとモック動作（UUIDをorderIdとして返す）。
# 本番化する際は LINE公式ドキュメント「アプリ内課金 → 購入予約API」の最新URLを設定する。
LINE_PURCHASE_RESERVE_URL=

# サーバーが listen するポート（デフォルト 4000）
PORT=4000
